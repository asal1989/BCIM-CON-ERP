{
  "expo": {
    "name": "BCIM ERP",
    "slug": "bcim-erp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.bcim.erp",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "googleServicesFile": "./google-services.json",
      "runtimeVersion": "1.0.0"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F172A"
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "8c02ba7f-2bd0-4b1b-9327-481f1e69fc00"
      }
    },
    "owner": "asal1989",
    "updates": {
      "url": "https://u.expo.dev/8c02ba7f-2bd0-4b1b-9327-481f1e69fc00"
    },
    "ios": {
      "runtimeVersion": {
        "policy": "appVersion"
      }
    }
  }
}
